# ──────────────────────────────────────────
# AI Services
# ──────────────────────────────────────────
CEREBRAS_API_KEY=YOUR_CEREBRAS_KEY
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY

# ──────────────────────────────────────────
# Vast.ai (Optional, for auto-deployment)
# ──────────────────────────────────────────
VAST_API_KEY=YOUR_VAST_KEY
VAST_INSTANCE_ID=YOUR_VAST_INSTANCE_ID

# ──────────────────────────────────────────
# Notifications & System Admin
# ──────────────────────────────────────────
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_PASSWORD=YOUR_APP_PASSWORD
NOTIFY_EMAIL=your_email@gmail.com
NTFY_TOPIC=youtube_factory

# ──────────────────────────────────────────
# Web Dashboard Auth
# ──────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=YOUR_SECURE_PASSWORD
JWT_SECRET_KEY=YOUR_RANDOM_JWT_SECRET_32_CHARS_MIN

# ──────────────────────────────────────────
# Google Drive Mount
# ──────────────────────────────────────────
GDRIVE_MOUNT=/mnt/gdrive

# ──────────────────────────────────────────
# Channel Specific YouTube Google Accounts
# ──────────────────────────────────────────
HORROR_GOOGLE_ACCOUNT=horrorcrimestories@gmail.com
MANNERS_GOOGLE_ACCOUNT=mannerslearning@gmail.com
CARTOON_GOOGLE_ACCOUNT=cartoonkidstories@gmail.com

# ──────────────────────────────────────────
# Channel Specific Meta Access Tokens
# ──────────────────────────────────────────
HORROR_META_TOKEN=
HORROR_FB_PAGE_ID=
HORROR_IG_ACCOUNT_ID=

MANNERS_META_TOKEN=
MANNERS_FB_PAGE_ID=
MANNERS_IG_ACCOUNT_ID=

CARTOON_META_TOKEN=
CARTOON_FB_PAGE_ID=
CARTOON_IG_ACCOUNT_ID=

# ──────────────────────────────────────────
# Local ComfyUI Settings (VPS 2)
# ──────────────────────────────────────────
COMFYUI_URL=http://localhost:8188
PARALLEL_CHANNELS=1
